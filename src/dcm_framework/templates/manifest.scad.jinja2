//
//  Manifest parameters
//
{%- for parameter_name, parameter_value in parameters.items() %}
{%- if parameter_value is boolean %}
{{ parameter_name }} = {{ "true" if parameter_value else "false" }};
{%- elif parameter_value is string %}
{{ parameter_name }} = "{{ parameter_value }}";
{%- else %}
{{ parameter_name }} = {{ parameter_value }};
{%- endif %}
{%- endfor %}
